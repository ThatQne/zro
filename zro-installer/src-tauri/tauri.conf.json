{
  "productName": "zro Setup",
  "version": "0.1.0",
  "identifier": "com.zro.installer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Install zro",
        "width": 560,
        "height": 500,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "ThatQne",
    "icon": [
      "../../src-tauri/icons/32x32.png",
      "../../src-tauri/icons/128x128.png",
      "../../src-tauri/icons/icon.ico",
      "../../src-tauri/icons/icon.png"
    ]
  }
}
