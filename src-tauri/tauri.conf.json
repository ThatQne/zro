{
  "productName": "zro",
  "version": "0.1.1",
  "identifier": "com.zro.browser",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "zro",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true,
        "center": true,
        "browserExtensionsEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "ThatQne",
    "homepage": "https://thatqne.github.io/zro/",
    "shortDescription": "Fast, lightweight minimalist browser for Windows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": ["icons/icon.png"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "compression": "lzma",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ThatQne/zro/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3NzMyQUUwRDIzMDNERDgKUldUWVBURFM0Q3B6Snh2bVlJMTgwNjBRbDNvZjJLc3hubDMzZE9NOGJWK0h2Mk5UQTREMVNnUm0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
